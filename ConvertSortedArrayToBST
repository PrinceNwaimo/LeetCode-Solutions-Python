class TreeNode(object):
    def __init__(self, value):
        self.value = value
        self.left = None
        self.right = None
        
class ConvertSortedArrayToBST(object):
    def sortedArrayToBST(self, nums):
        """ :type nums: List[int] :rtype: TreeNode """
        if nums == []:
            return None
        elif len(nums) == 1:
            return TreeNode(nums[0])
        else:
            start = 0
            end = len(nums) - 1
            return self.helper(nums, start, end)
    def helper(self, nums, start, end):
        if len(nums) == 0 or start > end:
            return None
        else:
            mid = (start + end) // 2
            root = TreeNode(nums[mid])
            root.left = self.helper(nums, start, mid - 1)
            root.right = self.helper(nums, mid + 1, end)
            return root
        